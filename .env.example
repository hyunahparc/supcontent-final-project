# ============================================================
# .env.example — SUPCONTENT (moviemovie)
# Copy this file to ".env" and fill in your own values:
#     cp .env.example .env
# The real .env is gitignored and must NEVER be committed or
# shipped with secrets in clear.
# ============================================================

# -- Server -------------------------------------------------
PORT=3000

# -- Database -----------------------------------------------
# Local (non-Docker) connection string. When running with
# docker compose, this is overridden automatically to point
# at the "db" service, so you can leave it as-is for Docker.
DATABASE_URL=postgresql://supcontent:supcontent_password@localhost:5432/supcontent

# -- JWT ----------------------------------------------------
# Use a long random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=change_me_to_a_long_random_secret

# -- TMDB API -----------------------------------------------
# Get a free key at https://www.themoviedb.org/ → Settings → API
TMDB_API_KEY=your_tmdb_api_key
TMDB_BASE_URL=https://api.themoviedb.org/3

# -- Google OAuth2 ------------------------------------------
# From https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# Mobile OAuth callback — only for mobile Google login; must be a PUBLIC https URL
# (deployed backend or an ngrok tunnel), then register it in Google Cloud Console.
GOOGLE_MOBILE_CALLBACK_URL=https://your-public-backend-host/api/auth/google/callback

# -- Frontend -----------------------------------------------
CLIENT_URL=http://localhost:5173

# -- Supabase (avatar uploads) ------------------------------
# From your Supabase project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# -- Docker PostgreSQL --------------------------------------
# Credentials used by the "db" service in docker-compose
POSTGRES_DB=supcontent
POSTGRES_USER=supcontent
POSTGRES_PASSWORD=supcontent_password

# -- Docker app URLs ----------------------------------------
CORS_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173
VITE_API_URL=http://localhost:5173
