# ============================================================
# supcontent-backend/.env.example
# Used when running the backend LOCALLY (npm run dev / npm start).
# Copy to ".env" and fill in your own values:
#     cp .env.example .env
# (For Docker, the root-level .env is used instead — see project README.)
# ============================================================

# -- Server -------------------------------------------------
PORT=3000

# -- Database -----------------------------------------------
# Connection string to your local or hosted PostgreSQL instance.
DATABASE_URL=postgresql://user:password@localhost:5432/supcontent

# -- JWT ----------------------------------------------------
# Use a long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=change_me_to_a_long_random_secret

# -- TMDB API -----------------------------------------------
# Get a free key at https://www.themoviedb.org/ -> Settings -> API
TMDB_API_KEY=your_tmdb_api_key

# -- Google OAuth2 ------------------------------------------
# From https://console.cloud.google.com/ -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Web callback (local dev)
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# Mobile callback — must be a PUBLIC https URL reachable by the phone
# (your deployed backend, or an ngrok tunnel to your local backend)
GOOGLE_MOBILE_CALLBACK_URL=https://your-backend-host/api/auth/google/callback

# -- Frontend -----------------------------------------------
CLIENT_URL=http://localhost:5173

# -- Supabase (avatar uploads) ------------------------------
# From your Supabase project -> Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
