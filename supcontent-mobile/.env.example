# ============================================================
# supcontent-mobile/.env.example
# Copy to ".env" and set the URL of your backend API.
#     cp .env.example .env
# Expo only exposes variables prefixed with EXPO_PUBLIC_.
# The URL must end with /api.
# ============================================================

# Pick ONE depending on whether you need Google login in local dev:
#
# CASE 1 — You WANT mobile Google login in local development:
#   You MUST use a PUBLIC backend URL (the deployed backend, or your local
#   backend exposed via an ngrok tunnel). Google OAuth2 needs a public HTTPS
#   callback, so a LAN IP will not work. Also set GOOGLE_MOBILE_CALLBACK_URL
#   in the backend .env to "<that-public-url>/api/auth/google/callback".
EXPO_PUBLIC_API_URL=https://your-public-backend-host/api
#
# CASE 2 — You DON'T need Google login (email/password is enough):
#   Use your own machine's Wi-Fi LAN IP so Expo Go on your phone can reach
#   your local backend. Google login will NOT work with this option.
# EXPO_PUBLIC_API_URL=http://<your-wifi-ip>:3000/api
